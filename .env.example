# DevOpsGPT Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# API Gateway
API_KEY=your_api_gateway_key_here
API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/dev

# Firebase
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_APP_ID=your_firebase_app_id_here

# WebSocket (optional — disabled by default)
WS_URL=wss://your-ws-api-id.execute-api.us-east-1.amazonaws.com/dev

# Flutter build command:
# flutter run \
#   --dart-define=API_KEY=$API_KEY \
#   --dart-define=API_BASE_URL=$API_BASE_URL \
#   --dart-define=WS_URL=$WS_URL
